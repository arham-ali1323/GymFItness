{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/api/index"
    }
  ],
  "functions": {
    "backend/api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}